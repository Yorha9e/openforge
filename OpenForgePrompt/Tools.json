{
  "tools": [
    {
      "name": "read_file",
      "description": "Read contents of a file from the local filesystem or MinIO artifact store.",
      "input_schema": {
        "type": "object",
        "properties": {
          "path": { "type": "string", "description": "Absolute path to the file" },
          "offset": { "type": "integer", "description": "Line to start reading from" },
          "limit": { "type": "integer", "description": "Maximum lines to read" }
        },
        "required": ["path"]
      },
      "is_concurrency_safe": true,
      "is_read_only": true
    },
    {
      "name": "write_file",
      "description": "Create or overwrite a file.",
      "input_schema": {
        "type": "object",
        "properties": {
          "path": { "type": "string", "description": "Absolute path to the file" },
          "content": { "type": "string", "description": "File content" }
        },
        "required": ["path", "content"]
      },
      "is_concurrency_safe": false,
      "is_read_only": false
    },
    {
      "name": "edit_file",
      "description": "Perform exact string replacements in an existing file.",
      "input_schema": {
        "type": "object",
        "properties": {
          "path": { "type": "string", "description": "Absolute path to the file" },
          "old_string": { "type": "string", "description": "Text to replace" },
          "new_string": { "type": "string", "description": "Replacement text" },
          "replace_all": { "type": "boolean", "description": "Replace all occurrences", "default": false }
        },
        "required": ["path", "old_string", "new_string"]
      },
      "is_concurrency_safe": false,
      "is_read_only": false
    },
    {
      "name": "search_files",
      "description": "Fast file pattern matching (glob) across the repository.",
      "input_schema": {
        "type": "object",
        "properties": {
          "pattern": { "type": "string", "description": "Glob pattern, e.g. 'src/**/*.ts'" },
          "path": { "type": "string", "description": "Directory to search in" }
        },
        "required": ["pattern"]
      },
      "is_concurrency_safe": true,
      "is_read_only": true
    },
    {
      "name": "search_content",
      "description": "Search file contents with regex patterns (ripgrep). Supports full regex syntax, file type filters, and context lines.",
      "input_schema": {
        "type": "object",
        "properties": {
          "pattern": { "type": "string", "description": "Regular expression to search for" },
          "path": { "type": "string", "description": "File or directory to search" },
          "glob": { "type": "string", "description": "Glob filter for file names" },
          "output_mode": { "type": "string", "enum": ["content", "files_with_matches", "count"] },
          "-A": { "type": "integer", "description": "Lines after match" },
          "-B": { "type": "integer", "description": "Lines before match" },
          "-C": { "type": "integer", "description": "Lines before and after match" }
        },
        "required": ["pattern"]
      },
      "is_concurrency_safe": true,
      "is_read_only": true
    },
    {
      "name": "bash",
      "description": "Execute a shell command. Profile-aware: minimal profile uses LocalShellExecutor (host direct spawn, dangerous commands blocked, path restricted); standard/enterprise profiles use DockerSandboxExecutor (isolated container with seccomp, --read-only, --cap-drop=ALL, cgroup limits: 2G/2CPU/100pids, network isolated). Implements StreamingTool for real-time output. Dangerous commands (rm -rf /, sudo, dd, mkfs, curl|bash) are ALWAYS blocked regardless of profile.",
      "input_schema": {
        "type": "object",
        "properties": {
          "command": { "type": "string", "description": "The command to execute" },
          "workdir": { "type": "string", "description": "Working directory for the command" },
          "timeout_ms": { "type": "integer", "description": "Timeout in milliseconds (max 600000)" }
        },
        "required": ["command"]
      },
      "is_concurrency_safe": false,
      "is_read_only": false,
      "requires_file_lock": true
    },
    {
      "name": "lsp_hover",
      "description": "Get hover information (type, documentation) for a symbol using the Language Server Protocol.",
      "input_schema": {
        "type": "object",
        "properties": {
          "file_path": { "type": "string", "description": "Absolute path to file" },
          "line": { "type": "integer", "description": "1-based line number" },
          "character": { "type": "integer", "description": "1-based character offset" }
        },
        "required": ["file_path", "line", "character"]
      },
      "is_concurrency_safe": true,
      "is_read_only": true
    },
    {
      "name": "lsp_definition",
      "description": "Go to the definition of a symbol.",
      "input_schema": {
        "type": "object",
        "properties": {
          "file_path": { "type": "string" },
          "line": { "type": "integer" },
          "character": { "type": "integer" }
        },
        "required": ["file_path", "line", "character"]
      },
      "is_concurrency_safe": true,
      "is_read_only": true
    },
    {
      "name": "lsp_references",
      "description": "Find all references to a symbol across the codebase.",
      "input_schema": {
        "type": "object",
        "properties": {
          "file_path": { "type": "string" },
          "line": { "type": "integer" },
          "character": { "type": "integer" }
        },
        "required": ["file_path", "line", "character"]
      },
      "is_concurrency_safe": true,
      "is_read_only": true
    },
    {
      "name": "lsp_symbols",
      "description": "Get all symbols (functions, classes, variables) in a document.",
      "input_schema": {
        "type": "object",
        "properties": {
          "file_path": { "type": "string" }
        },
        "required": ["file_path"]
      },
      "is_concurrency_safe": true,
      "is_read_only": true
    },
    {
      "name": "analyze_topology",
      "description": "Analyze the monorepo and generate a cross-stack dependency graph. Parses frontend HTTP calls + backend route registrations, matches API endpoints, builds unified topology at 3 levels (Business / Technical / Data Flow).",
      "input_schema": {
        "type": "object",
        "properties": {
          "project_path": { "type": "string", "description": "Project root path" },
          "level": { "type": "string", "enum": ["L1_business", "L2_technical", "L3_dataflow"], "description": "Topology detail level" },
          "modules": { "type": "array", "items": { "type": "string" }, "description": "Specific modules to analyze (empty = all)" }
        },
        "required": ["project_path"]
      },
      "is_concurrency_safe": true,
      "is_read_only": true
    },
    {
      "name": "acquire_file_lock",
      "description": "Acquire a file-level lock before modifying a file. Required before any write operation.",
      "input_schema": {
        "type": "object",
        "properties": {
          "file_path": { "type": "string", "description": "Path to lock" },
          "operation": { "type": "string", "enum": ["write", "read_only"] },
          "estimated_duration_seconds": { "type": "integer", "description": "Estimated duration for timeout calculation" }
        },
        "required": ["file_path", "operation"]
      },
      "is_concurrency_safe": false,
      "is_read_only": false
    },
    {
      "name": "release_file_lock",
      "description": "Release a previously acquired file lock.",
      "input_schema": {
        "type": "object",
        "properties": {
          "file_path": { "type": "string" }
        },
        "required": ["file_path"]
      },
      "is_concurrency_safe": false,
      "is_read_only": false
    },
    {
      "name": "create_pipeline",
      "description": "Create a new Pipeline or sub-Pipeline for a given project.",
      "input_schema": {
        "type": "object",
        "properties": {
          "project_id": { "type": "string" },
          "title": { "type": "string", "description": "Pipeline title" },
          "parent_pipeline_id": { "type": "string", "description": "For sub-Pipeline branching" },
          "level": { "type": "string", "enum": ["L1", "L2", "L3", "L4"] }
        },
        "required": ["project_id", "title", "level"]
      },
      "is_concurrency_safe": false,
      "is_read_only": false
    },
    {
      "name": "request_gate_approval",
      "description": "Submit current stage artifacts for Gate approval. Triggers notification to reviewers.",
      "input_schema": {
        "type": "object",
        "properties": {
          "pipeline_id": { "type": "string" },
          "stage": { "type": "string", "enum": ["clarify", "decompose", "impl", "test", "deploy", "verify"] },
          "summary": { "type": "string", "description": "Stage summary for reviewer" },
          "changed_files": { "type": "array", "items": { "type": "string" } },
          "test_results": { "type": "object", "description": "Test pass/fail summary" }
        },
        "required": ["pipeline_id", "stage", "summary"]
      },
      "is_concurrency_safe": false,
      "is_read_only": false
    },
    {
      "name": "save_checkpoint",
      "description": "Persist current agent state as a checkpoint for crash recovery.",
      "input_schema": {
        "type": "object",
        "properties": {
          "pipeline_id": { "type": "string" },
          "stage": { "type": "string" },
          "trigger": { "type": "string", "enum": ["auto", "manual"] }
        },
        "required": ["pipeline_id", "stage"]
      },
      "is_concurrency_safe": false,
      "is_read_only": false
    },
    {
      "name": "initiate_backtrack",
      "description": "Request a DAG backtrack to revisit an earlier Pipeline stage.",
      "input_schema": {
        "type": "object",
        "properties": {
          "pipeline_id": { "type": "string" },
          "target_stage": { "type": "string", "enum": ["clarify", "decompose", "impl", "test", "deploy"] },
          "reason": { "type": "string" },
          "evidence": { "type": "string" }
        },
        "required": ["pipeline_id", "target_stage", "reason", "evidence"]
      },
      "is_concurrency_safe": false,
      "is_read_only": false
    },
    {
      "name": "report_failure",
      "description": "Classify and report a Pipeline failure through the error recovery chain.",
      "input_schema": {
        "type": "object",
        "properties": {
          "pipeline_id": { "type": "string" },
          "failure_code": { "type": "string", "enum": ["MODEL_HALLUCINATION", "PROMPT_WEAKNESS", "DEPENDENCY_CONFLICT", "SANDBOX_TIMEOUT", "REPO_BUG", "CONTEXT_OVERFLOW", "TOKEN_QUOTA_EXCEEDED", "UNKNOWN"] },
          "error_log": { "type": "string" },
          "stage": { "type": "string" },
          "model": { "type": "string" },
          "files_involved": { "type": "array", "items": { "type": "string" } },
          "prompt_version": { "type": "string" }
        },
        "required": ["pipeline_id", "failure_code", "error_log"]
      },
      "is_concurrency_safe": false,
      "is_read_only": false
    },
    {
      "name": "write_knowledge_delta",
      "description": "Write learned preferences/patterns back to the Learning Engine after Pipeline completion.",
      "input_schema": {
        "type": "object",
        "properties": {
          "project_id": { "type": "string" },
          "pipeline_id": { "type": "string" },
          "preferences": { "type": "array", "items": { "type": "object", "properties": { "key": { "type": "string" }, "value": { "type": "string" }, "source": { "type": "string" } } } },
          "trajectory_summary": { "type": "object", "description": "Compressed trajectory for L3 learning" }
        },
        "required": ["project_id", "pipeline_id"]
      },
      "is_concurrency_safe": false,
      "is_read_only": false
    },
    {
      "name": "query_knowledge",
      "description": "Query the Learning Engine for relevant preferences/patterns by embedding similarity.",
      "input_schema": {
        "type": "object",
        "properties": {
          "project_id": { "type": "string" },
          "query": { "type": "string", "description": "Natural language query" },
          "top_k": { "type": "integer", "description": "Number of results", "default": 5 },
          "level": { "type": "string", "enum": ["L1_static", "L2_feedback", "L3_trajectory", "L4_embedding", "all"] }
        },
        "required": ["project_id", "query"]
      },
      "is_concurrency_safe": true,
      "is_read_only": true
    },
    {
      "name": "manage_sandbox",
      "description": "Create, start, stop, or remove a sandbox container for code execution.",
      "input_schema": {
        "type": "object",
        "properties": {
          "action": { "type": "string", "enum": ["create", "start", "stop", "remove", "list"] },
          "image": { "type": "string", "description": "Docker image tag (version-locked, e.g. v20260519)" },
          "container_id": { "type": "string" }
        },
        "required": ["action"]
      },
      "is_concurrency_safe": false,
      "is_read_only": false
    },
    {
      "name": "generate_artifact_url",
      "description": "Generate a signed download URL for an artifact stored in MinIO.",
      "input_schema": {
        "type": "object",
        "properties": {
          "pipeline_id": { "type": "string" },
          "artifact_id": { "type": "string" },
          "expires_in_seconds": { "type": "integer", "default": 3600 }
        },
        "required": ["pipeline_id", "artifact_id"]
      },
      "is_concurrency_safe": true,
      "is_read_only": true
    },
    {
      "name": "validate_artifact_hash",
      "description": "Verify artifact integrity by comparing current SHA256 against the stored hash (for TOCTOU protection).",
      "input_schema": {
        "type": "object",
        "properties": {
          "pipeline_id": { "type": "string" },
          "stage": { "type": "string" }
        },
        "required": ["pipeline_id", "stage"]
      },
      "is_concurrency_safe": true,
      "is_read_only": true
    },
    {
      "name": "list_models",
      "description": "List available LLM models from the Model Registry with their aliases, providers, feature flags, and fallback chains.",
      "input_schema": {
        "type": "object",
        "properties": {
          "provider": { "type": "string", "description": "Filter by provider (anthropic/deepseek/openai/gemini), omit for all" }
        },
        "required": []
      },
      "is_concurrency_safe": true,
      "is_read_only": true
    },
    {
      "name": "switch_model",
      "description": "Switch the LLM model by alias (e.g. 'sonnet', 'opus', 'deepseek'). The Router resolves the alias to actual ModelID, BaseURL, and API key via the Model Registry. No Pipeline restart required — takes effect on the next agent turn.",
      "input_schema": {
        "type": "object",
        "properties": {
          "pipeline_id": { "type": "string" },
          "model_alias": { "type": "string", "description": "Model alias from registry: opus, sonnet, haiku, deepseek, deepseek-r1, gpt-5, gemini" }
        },
        "required": ["pipeline_id", "model_alias"]
      },
      "is_concurrency_safe": false,
      "is_read_only": false
    },
    {
      "name": "check_token_budget",
      "description": "Check remaining token budget for the current Pipeline and project monthly quota.",
      "input_schema": {
        "type": "object",
        "properties": {
          "pipeline_id": { "type": "string" }
        },
        "required": ["pipeline_id"]
      },
      "is_concurrency_safe": true,
      "is_read_only": true
    },
    {
      "name": "set_permission_mode",
      "description": "Request a change of PermissionMode for the Pipeline (requires PM or Admin approval for upgrade).",
      "input_schema": {
        "type": "object",
        "properties": {
          "pipeline_id": { "type": "string" },
          "mode": { "type": "string", "enum": ["plan", "auto", "default", "bypass"] },
          "reason": { "type": "string" }
        },
        "required": ["pipeline_id", "mode", "reason"]
      },
      "is_concurrency_safe": false,
      "is_read_only": false
    },
    {
      "name": "query_module_ownership",
      "description": "Look up which team owns a given file or module path (for 二维归属 routing).",
      "input_schema": {
        "type": "object",
        "properties": {
          "project_id": { "type": "string" },
          "file_path": { "type": "string" }
        },
        "required": ["project_id", "file_path"]
      },
      "is_concurrency_safe": true,
      "is_read_only": true
    }
  ]
}
